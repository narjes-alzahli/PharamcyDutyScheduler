# Environment Configuration
# Copy this file to .env and update with your values
# .env is gitignored and will not be committed

# ============================================================================
# PRODUCTION (Server)
# ============================================================================
# For production server, only DATABASE_URL is required:
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/pharmacy_scheduler

# ============================================================================
# DEVELOPMENT (Local)
# ============================================================================
# For local development, configure these:

# Backend Port (default: 8000)
BACKEND_PORT=8000

# Database Configuration
# For SQLite (default - simple, no setup needed):
DATABASE_URL=sqlite:///./roster.db

# For PostgreSQL (if you prefer):
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/pharmacy_scheduler
